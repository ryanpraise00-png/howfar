# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/howfar?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Min 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET="change-me-in-production-min-32-chars"

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300

# ── Africa's Talking SMS ──────────────────────────────────────────────────────
# Sandbox: AT_USERNAME=sandbox, any string for AT_API_KEY
# Production: use your live account credentials from https://account.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your-at-api-key
# AT_SENDER_ID=HowFar   # optional alphanumeric sender ID (not available in sandbox)

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# In development (NODE_ENV != production) all origins are allowed.
CORS_ORIGINS="https://howfar.app,https://www.howfar.app"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
