generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ChatType {
  DIRECT
  GROUP
}

enum MemberRole {
  MEMBER
  ADMIN
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  VOICE
  DOCUMENT
  LOCATION
  CONTACT_CARD
  SYSTEM
}

enum StatusType {
  IMAGE
  TEXT
  VIDEO
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String
  about        String   @default("Hey! I'm on HowFar")
  avatarUrl    String?
  createdAt    DateTime @default(now())
  lastSeen     DateTime @default(now())
  isOnline     Boolean  @default(false)
  twoStepPin   String?
  twoStepEmail String?

  // Relations
  sentMessages    Message[]         @relation("MessageSender")
  chatMemberships ChatMember[]
  contacts        Contact[]         @relation("ContactOwner")
  contactOf       Contact[]         @relation("ContactTarget")
  blockedUsers    BlockedUser[]     @relation("Blocker")
  blockedBy       BlockedUser[]     @relation("Blocked")
  statusPosts     StatusPost[]
  statusViews     StatusView[]
  messageReceipts MessageReceipt[]
  messageReactions MessageReaction[]
}

// ─── Contact ──────────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  ownerId   String
  contactId String
  nickname  String?
  createdAt DateTime @default(now())

  owner   User @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  contact User @relation("ContactTarget", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contactId])
}

// ─── BlockedUser ──────────────────────────────────────────────────────────────

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Chat {
  id          String   @id @default(cuid())
  type        ChatType
  name        String?
  description String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  ChatMember[]
  messages Message[]
}

// ─── ChatMember ───────────────────────────────────────────────────────────────

model ChatMember {
  id     String     @id @default(cuid())
  chatId String
  userId String
  role   MemberRole @default(MEMBER)
  joinedAt DateTime @default(now())

  isMuted            Boolean   @default(false)
  mutedUntil         DateTime?
  isPinned           Boolean   @default(false)
  isArchived         Boolean   @default(false)
  disappearingMsgTtl Int?
  lastReadMessageId  String?
  unreadCount        Int       @default(0)

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id          String      @id @default(cuid())
  chatId      String
  senderId    String
  type        MessageType @default(TEXT)
  content     String?
  mediaUrl    String?
  mediaSize   Int?
  mediaName   String?
  duration    Int?
  lat         Float?
  lng         Float?
  isForwarded Boolean     @default(false)
  replyToId   String?
  isDeleted   Boolean     @default(false)
  deletedFor  String[]
  createdAt   DateTime    @default(now())

  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender  User    @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo Message? @relation("MessageReply", fields: [replyToId], references: [id])
  replies Message[] @relation("MessageReply")

  receipts  MessageReceipt[]
  reactions MessageReaction[]
}

// ─── MessageReceipt ───────────────────────────────────────────────────────────

model MessageReceipt {
  id          String    @id @default(cuid())
  messageId   String
  userId      String
  deliveredAt DateTime?
  readAt      DateTime?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

// ─── MessageReaction ──────────────────────────────────────────────────────────

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

// ─── StatusPost ───────────────────────────────────────────────────────────────

model StatusPost {
  id        String     @id @default(cuid())
  userId    String
  type      StatusType
  content   String?
  mediaUrl  String?
  bgColor   String?
  caption   String?
  expiresAt DateTime
  createdAt DateTime   @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  views StatusView[]
}

// ─── StatusView ───────────────────────────────────────────────────────────────

model StatusView {
  id           String   @id @default(cuid())
  statusPostId String
  viewerId     String
  viewedAt     DateTime @default(now())
  reaction     String?

  statusPost StatusPost @relation(fields: [statusPostId], references: [id], onDelete: Cascade)
  viewer     User       @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([statusPostId, viewerId])
}
